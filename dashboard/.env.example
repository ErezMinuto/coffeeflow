# ============================================
# Minuto Dashboard — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git!
# ============================================

# Supabase — CoffeeFlow prod project (single source of truth for all data)
VITE_SUPABASE_URL=https://ytydgldyeygpzmlxvpvb.supabase.co
VITE_SUPABASE_ANON_KEY=your_coffeeflow_anon_key_here

# Clerk (optional — can remove if not using auth)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Meta (Facebook App)
VITE_META_APP_ID=your_app_id_here

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ============================================
# Supabase Edge Functions secrets
# Set via: supabase secrets set KEY=value
# ============================================
# META_APP_SECRET=your_app_secret
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_DEVELOPER_TOKEN=your_dev_token        ← pending approval
# GOOGLE_CUSTOMER_ID=123-456-7890
