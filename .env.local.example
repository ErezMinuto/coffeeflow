# CoffeeFlow — Local Environment Template
# Copy this file to .env.local and fill in the dev values.
# NEVER commit .env.local — it is in .gitignore.
#
# Get these values from the team's shared secrets (ask the project owner).
# For local development, point at the DEV Supabase project, not production.

# ── Supabase (use DEV project values) ──────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://<dev-project-id>.supabase.co
REACT_APP_SUPABASE_ANON_KEY=<dev-anon-key>

# ── Clerk (same key works for dev and prod) ────────────────────────────────────
REACT_APP_CLERK_PUBLISHABLE_KEY=<clerk-publishable-key>
